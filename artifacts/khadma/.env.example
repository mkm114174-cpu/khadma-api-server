# API server hostname (no scheme) — baked into standalone Android/iOS builds.
EXPO_PUBLIC_DOMAIN=your-api.onrender.com

# Neon Auth URL from Neon Console → Project → Auth → Configuration
EXPO_PUBLIC_NEON_AUTH_URL=https://ep-xxx.neonauth.region.aws.neon.build/neondb/auth

# Google Maps — required for the map on Android release builds.
GOOGLE_MAPS_API_KEY=
